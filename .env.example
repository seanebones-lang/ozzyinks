# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sanity CMS — https://www.sanity.io/manage
# After creating a project, add http://localhost:3000 (and production URL) under API → CORS origins.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# xAI (Grok) — server only
XAI_API_KEY=
XAI_MODEL=grok-2-latest

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: persist bookings across serverless instances
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email (Resend) — booking, deposit alerts, artist-lead form → CONTACT_NOTIFY_EMAIL or OZZY_CONTACT_EMAIL in code
RESEND_API_KEY=
# Verified sender, e.g. "Ozzy Fox <bookings@yourdomain.com>" (verify domain in Resend)
RESEND_FROM_EMAIL=
# Optional override for the inbox that receives site notifications (default: Ozzyfox444@gmail.com in lib/constants)
CONTACT_NOTIFY_EMAIL=

# Sanity: paste the same secret in manage.sanity.io → API → Webhooks → Signing secret
SANITY_REVALIDATE_SECRET=

# Optional analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
